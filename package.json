{
  "name": "backyard-defense",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "http-server . -p 4173 -c-1",
    "desktop:dev": "electron .",
    "build:exe": "electron-builder --win portable",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "build": {
    "appId": "com.pvz.backyarddefense",
    "productName": "Backyard Defense",
    "files": [
      "electron/**/*",
      "src/**/*",
      "index.html",
      "styles.css",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "http-server": "^14.1.1",
    "vitest": "^2.1.8"
  }
}
